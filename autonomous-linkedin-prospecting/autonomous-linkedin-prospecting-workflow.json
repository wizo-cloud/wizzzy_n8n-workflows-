    {
      "parameters": {
        "jsCode": "// Get the output from the AI Agent node\nconst items = $input.all();\n\nconst results = items.map(item => {\n  let rawOutput = item.json.output;\n  \n  // Remove markdown code fences if present (```json ... ```)\n  rawOutput = rawOutput.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  \n  // Parse the cleaned JSON string\n  const parsed = JSON.parse(rawOutput);\n  \n  return {\n    json: {\n      full_name: parsed.full_name,\n      verified_email: parsed.verified_email,\n      personalized_message: parsed.personalized_message\n    }\n  };\n});\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        -736
      ],
      "id": "f1e9dda7-9034-42a7-8562-072fe7314e84",
      "name": "Code"
    },
    {
      "parameters": {
        "jsCode": "// Check if the scraped data has valid profile info\nconst items = $input.all();\nconst validItems = [];\nconst invalidItems = [];\n\nfor (const item of items) {\n  const basicInfo = item.json.basic_info;\n  \n  // If basic_info is missing or fullname is empty, it's an invalid profile\n  if (!basicInfo || !basicInfo.fullname || basicInfo.fullname.trim() === '') {\n    invalidItems.push(item);\n  } else {\n    validItems.push(item);\n  }\n}\n\n// If no valid items found, throw an error to route to error handler\nif (validItems.length === 0) {\n  throw new Error('No valid profile data returned - URL may be invalid or profile is private');\n}\n\nreturn validItems;"
      },
